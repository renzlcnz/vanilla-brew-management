{
  "expo": {
    "name": "Vanilla Brew SMS",
    "slug": "MyExpoProject",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/company-logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/sms-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#202020"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/company-logo.png",
        "backgroundColor": "#202020"
      },
      "package": "com.renz.vanillabrew"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}